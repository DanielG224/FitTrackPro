@page
@model RegisterModel
@{
    ViewData["Title"] = "Zarejestruj się";
}

<div class="container">
    <div class="row justify-content-center auth-row-centered">
        <div class="col-md-8 col-lg-5">
            <section class="text-center">
                <h1 class="mb-3">@ViewData["Title"]</h1>
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <h2 class="fs-4">Utwórz nowe konto.</h2>
                    <hr class="mb-3" />

                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="mb-3 text-start">
                        <label asp-for="Input.Email" class="form-label">Adres e-mail</label>
                        <input asp-for="Input.Email" class="form-control input-vertical-center" autocomplete="username" aria-required="true" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3 text-start">
                        <label asp-for="Input.Password" class="form-label">Hasło</label>
                        <input asp-for="Input.Password" class="form-control input-vertical-center" autocomplete="new-password" aria-required="true" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3 text-start">
                        <label asp-for="Input.ConfirmPassword" class="form-label">Potwierdź hasło</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control input-vertical-center" autocomplete="new-password" aria-required="true" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary mb-2">Zarejestruj</button>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}