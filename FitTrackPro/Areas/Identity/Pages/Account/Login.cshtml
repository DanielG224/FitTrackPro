@page
@model LoginModel

@{
    ViewData["Title"] = "Zaloguj się";
}

<div class="container">
    <div class="row justify-content-center auth-row-centered">
        <div class="col-md-8 col-lg-5">
            <section class="text-center">
                <h1 class="mb-3">@ViewData["Title"]</h1>
                <form id="account" method="post">
                    <h2 class="fs-4">Użyj lokalnego konta do logowania.</h2>
                    <hr class="mb-3" />

                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="mb-3 text-start">
                        <label asp-for="Input.Email" class="form-label">Adres e-mail</label>
                        <input asp-for="Input.Email" class="form-control input-vertical-center" autocomplete="username" aria-required="true" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3 text-start">
                        <label asp-for="Input.Password" class="form-label">Hasło</label>
                        <input asp-for="Input.Password" class="form-control input-vertical-center" autocomplete="current-password" aria-required="true" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="checkbox mb-3 text-start">
                        <label asp-for="Input.RememberMe" class="form-label">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            Zapamiętaj mnie
                        </label>
                    </div>

                    <div>
                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary mb-2">Zaloguj</button>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}