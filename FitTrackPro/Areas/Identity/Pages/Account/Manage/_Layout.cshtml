@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row justify-content-center manage-row-aligned">
        <div class="col-md-10 col-lg-8">
            <section class="text-center w-100">
                <h1 class="mb-3">Zarządzaj kontem</h1>
                <h2 class="fs-4">Zmień ustawienia swojego profilu</h2>
                <hr class="mb-3" />

                <div class="row text-start mt-4">
                    <div class="col-md-4 mb-4">
                        <partial name="_ManageNav" />
                    </div>
                    <div class="col-md-8">
                        @RenderBody()
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}