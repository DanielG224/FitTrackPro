@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Zmień hasło";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="mb-3 text-center text-md-start">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<form id="change-password-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
    
    <div class="mb-3 text-start">
        <label asp-for="Input.OldPassword" class="form-label">Obecne hasło</label>
        <input asp-for="Input.OldPassword" class="form-control input-vertical-center" autocomplete="current-password" aria-required="true" />
        <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
    </div>
    
    <div class="mb-3 text-start">
        <label asp-for="Input.NewPassword" class="form-label">Nowe hasło</label>
        <input asp-for="Input.NewPassword" class="form-control input-vertical-center" autocomplete="new-password" aria-required="true" />
        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
    </div>
    
    <div class="mb-3 text-start">
        <label asp-for="Input.ConfirmPassword" class="form-label">Potwierdź nowe hasło</label>
        <input asp-for="Input.ConfirmPassword" class="form-control input-vertical-center" autocomplete="new-password" aria-required="true" />
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
    </div>
    
    <button type="submit" class="w-100 btn btn-lg btn-primary mb-2">Zaktualizuj hasło</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}