@{
    ViewData["Title"] = "Panel administratora";
}

<div class="container mt-5">

    <div class="mb-5">
        <h1 class="fw-bold">
            Panel administratora
        </h1>

        <p class="text-light">
            Zarządzaj aplikacją FitTrackPro.
        </p>
    </div>

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <h5>Łączna liczba ćwiczeń</h5>

                    <h1 class="fw-bold mt-3">
                        @ViewBag.ExercisesCount
                    </h1>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <h5>Łączna liczba planów treningowych</h5>

                    <h1 class="fw-bold mt-3">
                        @ViewBag.WorkoutPlansCount
                    </h1>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <h5>Łączna liczba użytkowników</h5>

                    <h1 class="fw-bold mt-3">
                        @ViewBag.UsersCount
                    </h1>

                </div>

            </div>

        </div>

    </div>

    <div class="mt-5 d-flex gap-3 flex-wrap">

        <a asp-controller="Exercises"
           asp-action="Index"
           class="btn btn-primary">

            Zarządzaj ćwiczeniami

        </a>

        <a asp-controller="WorkoutPlans"
           asp-action="Index"
           class="btn btn-success">

            Zarządzaj planami treningowymi

        </a>

    </div>

</div>