@model FitTrackPro.Models.WorkoutPlan

@{
    ViewData["Title"] = "Szczegóły planu treningowego";
}

<div class="container mt-5">

    <div class="mb-4 text-center">
        <h1 class="fw-bold">Szczegóły planu treningowego</h1>
        <p class="text-muted">
            Informacje o wybranym programie treningowym w FitTrackPro.
        </p>
    </div>

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0">

                <div class="card-body p-5">

                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-4">

                        <h2 class="fw-bold text-primary mb-0">
                            @Model.Name
                        </h2>

                        <div>
                            <span class="badge bg-success fs-6 px-3 py-2">
                                Poziom: @Model.Level
                            </span>
                        </div>

                    </div>

                    <hr class="mb-4" />

                    <div class="mb-4">

                        <h5 class="fw-bold text-secondary mb-2">
                            Opis planu
                        </h5>

                        <p class="card-text fs-5 text-dark"
                           style="white-space: pre-line;">
                            @Model.Description
                        </p>

                    </div>

                    @if (Model.WorkoutPlanExercises != null && Model.WorkoutPlanExercises.Any())
                    {
                        <div class="mt-5 mb-4">

                            <h5 class="fw-bold text-secondary mb-3">
                                📋 Lista ćwiczeń w planie
                            </h5>

                            <div class="row g-3">

                                @foreach (var item in Model.WorkoutPlanExercises)
                                {
                                    <div class="col-md-6">

                                        <div class="card h-100 border-light bg-light shadow-sm">

                                            <div class="card-body d-flex justify-content-between align-items-center">

                                                <div>
                                                    <h6 class="fw-bold mb-1 text-dark">
                                                        @item.Exercise?.Name
                                                    </h6>

                                                    <small class="text-muted">
                                                        Partia: @item.Exercise?.MuscleGroup
                                                    </small>
                                                </div>

                                                <div class="text-end">
                                                    <span class="badge bg-secondary px-2 py-1">
                                                        @item.Sets serii x @item.Reps powt.
                                                    </span>
                                                </div>

                                            </div>

                                        </div>

                                    </div>
                                }

                            </div>

                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mt-4">
                            Ten plan nie posiada jeszcze żadnych ćwiczeń.
                        </div>
                    }

                    <div class="d-flex justify-content-center gap-3 flex-wrap mt-5">

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="WorkoutPlanExercises"
                               asp-action="Create"
                               asp-route-workoutPlanId="@Model.Id"
                               class="btn btn-success px-4">
                                + Dodaj ćwiczenie
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@Model.Id"
                               class="btn btn-primary px-4">
                                Edytuj plan
                            </a>
                        }

                        <a asp-action="Index"
                           class="btn btn-outline-secondary px-4">
                            Powrót do listy
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>