@model IEnumerable<FitTrackPro.Models.WorkoutPlan>

@{
    ViewData["Title"] = "Plany treningowe";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Plany treningowe</h1>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success">Dodaj nowy plan</a>
        }
    </div>

    <div class="mb-4">
        <div class="input-group input-group-lg shadow-sm">
            <span class="input-group-text bg-white"><i class="bi bi-search">🔍</i></span>
            <input type="text" id="planSearch" class="form-control" autocomplete="off" placeholder="Zacznij wpisywać nazwę lub poziom..." />
        </div>
    </div>

    <div class="row" id="planContainer">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4 exercise-card-item" data-search="@(item.Name?.ToLower()) @(item.Level?.ToLower())">
                <div class="card h-100 shadow-sm border-0 bg-light">
                    <div class="card-img-top bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 220px;">
                        <span>Plan treningowy</span>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h4 class="card-title fw-bold">@item.Name</h4>
                        <h6 class="card-subtitle mb-3 text-muted">
                            <span class="badge bg-secondary">@item.Level</span>
                        </h6>
                        <p class="card-text flex-grow-1 text-secondary">
                            @(item.Description != null && item.Description.Length > 120 ?
                                item.Description.Substring(0, 120) + "..." : item.Description)
                        </p>

                        <div class="mt-3">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary w-100 mb-2">Szczegóły planu</a>

                            @if (User.IsInRole("Admin"))
                            {
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning w-50">Edytuj</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger w-50">Usuń</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div id="noResultsMsg" class="alert alert-info text-center" style="display: none;">
        Nie znaleziono planów treningowych pasujących do wyszukiwania.
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById('planSearch');
            const cards = document.querySelectorAll('.exercise-card-item');
            const noResultsMsg = document.getElementById('noResultsMsg');

            function filterCards() {
                let searchValue = searchInput.value.toLowerCase().trim();
                let hasVisibleCards = false;

                if (searchValue === "") {
                    cards.forEach(card => card.style.display = 'block');
                    noResultsMsg.style.display = 'none';
                    return;
                }

                cards.forEach(card => {
                    let searchData = card.getAttribute('data-search') || "";
                    if (searchData.includes(searchValue)) {
                        card.style.display = 'block';
                        hasVisibleCards = true;
                    } else {
                        card.style.display = 'none';
                    }
                });
                noResultsMsg.style.display = hasVisibleCards ? 'none' : 'block';
            }

            searchInput.addEventListener('input', filterCards);
            filterCards();
        });
    </script>
}