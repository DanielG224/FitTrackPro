@using FitTrackPro.Models

@{
    var exercise = ViewBag.ExerciseOfTheDay as Exercise;
}

<div class="hero">
    <div class="container text-center">
        <h1>Zmień swoją sylwetkę</h1>
        <p>Odkrywaj plany treningowe, ćwiczenia i osiągaj swoje cele fitness z FitTrackPro.</p>
        <div class="mt-4">
            <a asp-controller="Exercises" asp-action="Index" class="btn btn-primary btn-lg me-3">
                Przeglądaj ćwiczenia
            </a>
            <a asp-controller="WorkoutPlans" asp-action="Index" class="btn btn-outline-light btn-lg">
                Plany treningowe
            </a>
        </div>
    </div>
</div>

<section class="container mt-5">
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="fw-bold text-success">@ViewBag.ExerciseCount+</h2>
                    <h4 class="mt-3">Ćwiczeń</h4>
                    <p>Profesjonalne ćwiczenia dla każdej grupy mięśniowej.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="fw-bold text-success">@ViewBag.WorkoutPlanCount+</h2>
                    <h4 class="mt-3">Planów treningowych</h4>
                    <p>Rozpisane programy treningowe dla każdego poziomu zaawansowania.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="fw-bold text-success">100%</h2>
                    <h4 class="mt-3">Responsywności</h4>
                    <p>W pełni zoptymalizowana aplikacja na komputer, tablet i telefon.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@if (exercise != null)
{
    <section class="container mt-5">
        <div class="card shadow-lg">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <h2 class="fw-bold">🏆 Ćwiczenie dnia</h2>
                    <p class="text-dark">Codziennie prezentujemy jedno wybrane ćwiczenie z naszej bazy.</p>
                </div>
                <div class="row align-items-center">
                    <div class="col-md-4 text-center">
                        @if (!string.IsNullOrEmpty(exercise.ImageUrl))
                        {
                            <img src="@exercise.ImageUrl" class="img-fluid rounded shadow" alt="@exercise.Name" style="max-height:300px;" />
                        }
                    </div>
                    <div class="col-md-8">
                        <h3 class="fw-bold mb-3">@exercise.Name</h3>
                        <p>@exercise.Description</p>
                        <p><strong>Grupa mięśniowa:</strong> @exercise.MuscleGroup</p>
                        <p><strong>Poziom trudności:</strong> @exercise.Difficulty</p>
                        <a asp-controller="Exercises" asp-action="Index" class="btn btn-primary">Zobacz wszystkie ćwiczenia</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<section class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold">Dlaczego FitTrackPro?</h2>
        <p class="text-light">Wszystko czego potrzebujesz do zarządzania swoim treningiem.</p>
    </div>
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h4 class="fw-bold">Baza ćwiczeń</h4>
                    <p class="mt-3">Przeglądaj stale rozwijaną bazę ćwiczeń z opisami i zdjęciami.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h4 class="fw-bold">Plany treningowe</h4>
                    <p class="mt-3">Korzystaj z planów treningowych dla początkujących, średniozaawansowanych i zaawansowanych.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h4 class="fw-bold">Panel administratora</h4>
                    <p class="mt-3">Zarządzaj ćwiczeniami oraz planami treningowymi z poziomu panelu admina.</p>
                </div>
            </div>
        </div>
    </div>
</section>